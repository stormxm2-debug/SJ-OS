{
  "name": "sj-ai-company",
  "version": "0.0.0",
  "private": true,
  "description": "SJ AI Company — a desktop AI engineering organization. The CEO gives one instruction; the AI company executes. (MVP shell)",
  "author": "SJ AI Company",
  "license": "UNLICENSED",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "proxy:dev": "npm --prefix sj-ai-proxy run dev",
    "proxy:check": "node --check sj-ai-proxy/server.mjs",
    "proxy:status": "node scripts/proxy-status.mjs",
    "proxy:env": "node scripts/check-proxy-env.mjs",
    "proxy:kill": "node scripts/kill-proxy-port.mjs",
    "dev:all": "node scripts/dev-all.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
