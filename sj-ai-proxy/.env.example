# SJ OS AI Proxy — example environment variables.
# Copy to `.env` (which is gitignored) and fill in real values on the BACKEND ONLY.
# NEVER put OPENAI_API_KEY in the SJ OS renderer/frontend. NEVER commit .env.

# Enable the GPT brain. Defaults to false — the proxy returns a safe fallback
# until this is explicitly set to true AND a valid key is present.
OPENAI_ENABLED=false

# Your OpenAI API key. Server-side only.
OPENAI_API_KEY=

# Model used for /ai/chat completions.
OPENAI_MODEL=gpt-4o-mini

# Port the proxy listens on.
PORT=8787

# Allowed renderer origin(s) for CORS. Use a specific origin in production.
# '*' is convenient for local development only.
CORS_ORIGIN=*

# Upstream request timeout (ms).
OPENAI_TIMEOUT_MS=20000
