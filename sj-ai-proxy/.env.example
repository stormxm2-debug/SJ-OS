.# SJ OS AI Proxy — example environment variables.
# Copy to `.env` (which is gitignored) and fill in real values on the BACKEND ONLY.
# NEVER put OPENAI_API_KEY in the SJ OS renderer/frontend. NEVER commit .env.
# If a key ever leaks, rotate it immediately in the OpenAI dashboard.

# Enable the GPT brain. Defaults to false — the proxy returns a safe fallback
# until this is explicitly set to true AND a valid key is present.
OPENAI_ENABLED=false

# Your OpenAI API key. Server-side only. Placeholder shown — replace locally.
OPENAI_API_KEY=sk-your-key-here

# Model used for /ai/chat completions.
OPENAI_MODEL=gpt-4o-mini

# Speech-to-text model for Jarvis Voice Mode (POST /ai/transcribe).
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Max push-to-talk recording length (seconds). The renderer enforces this.
MAX_AUDIO_SECONDS=10

# Max accepted audio upload size (MB). Backend guard for /ai/transcribe.
MAX_AUDIO_UPLOAD_MB=10

# Upstream request timeout (ms).
OPENAI_TIMEOUT_MS=30000

# Comma-separated CORS allowlist of renderer origins. Use specific origins in
# production. '*' allows any (local development only).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Port the proxy listens on.
PORT=8787
