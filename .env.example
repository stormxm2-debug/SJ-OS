# SJ OS renderer (frontend) environment — example values.
# Copy to `.env` (gitignored) for local dev. NON-SECRET values only.
#
# IMPORTANT: NEVER put OPENAI_API_KEY here or anywhere in the renderer/frontend.
# The OpenAI key lives ONLY in the backend proxy (see sj-ai-proxy/.env.example).

# Turn on the GPT brain in the renderer. This only controls whether the renderer
# attempts to call the proxy — the proxy remains the real gate for the API key.
VITE_AI_PROXY_ENABLED=false

# URL of the SJ OS AI Proxy (POST /ai/chat, GET /health).
VITE_AI_PROXY_URL=http://localhost:8787

# Optional display-only label for the model shown in Settings.
VITE_AI_PROXY_MODEL_LABEL=gpt-4o-mini (server-side)
