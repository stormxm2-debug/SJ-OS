# SJ OS root environment — example values.
# Copy to `.env` (gitignored) for local desktop dev. Then run: npm run dev
#
# This file has TWO sections:
#   1. Electron Main AI Gateway  → the DEFAULT Jarvis AI/STT path for the desktop
#      app. The OpenAI key is read by the ELECTRON MAIN PROCESS only.
#   2. Legacy sj-ai-proxy (renderer) → optional/advanced fallback (VITE_* vars).
#
# SECURITY — read carefully:
#   - Put your real OPENAI_API_KEY ONLY in the root `.env` (never `.env.example`,
#     never a VITE_ variable, never renderer/frontend code, never a chat message).
#   - The key lives ONLY in the Electron main process. It is never exposed to the
#     renderer, preload, or logs.

# ── 1. Electron Main AI Gateway (desktop default) ────────────────────────────
# Read by the Electron MAIN process (src/main/services/ai-gateway). No separate
# proxy server, no localhost:8787, no CORS — `npm run dev` is all that's needed.

# Master switch for the main-process AI gateway (STT + status). Off by default.
OPENAI_ENABLED=false

# Your OpenAI API key. Set this ONLY in your local root `.env`, never here.
OPENAI_API_KEY=sk-your-key-here

# Chat model label (display only for now) and the speech-to-text model.
OPENAI_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Voice recording / upload guards (the renderer also caps recording length).
MAX_AUDIO_SECONDS=10
MAX_AUDIO_UPLOAD_MB=10

# ── 2. Legacy sj-ai-proxy (optional / advanced fallback) ─────────────────────
# NON-SECRET renderer values only. Used ONLY when you deliberately select the
# "Legacy Proxy" Jarvis engine and run the separate sj-ai-proxy server. Desktop
# Jarvis does NOT require any of these.

# Turn on the GPT brain proxy path in the renderer (legacy).
VITE_AI_PROXY_ENABLED=false

# URL of the legacy SJ OS AI Proxy (POST /ai/chat, GET /health).
VITE_AI_PROXY_URL=http://localhost:8787

# Optional display-only label for the model shown in Settings.
VITE_AI_PROXY_MODEL_LABEL=gpt-4o-mini (server-side)

# ── 3. Claude (보험금 청구비서) — sj-ai-proxy backend ─────────────────────────
# These go in sj-ai-proxy/.env (the proxy's OWN env), NOT the renderer. The
# Anthropic API key is read by the PROXY only and never exposed to the renderer.
# Get a key at console.anthropic.com. Powers the insurance claim assistant with
# native PDF + image document analysis. Uncomment + fill in sj-ai-proxy/.env:
# ANTHROPIC_ENABLED=true
# ANTHROPIC_MODEL=claude-opus-4-8        # or claude-sonnet-5 / claude-haiku-4-5 (cheaper)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
